{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/public/$1"
    },
    {
      "src": "/billing",
      "dest": "/public/billing.html"
    },
    {
      "src": "/login",
      "dest": "/public/login.html"
    },
    {
      "src": "/signup",
      "dest": "/public/signup.html"
    },
    {
      "src": "/medicines",
      "dest": "/public/medicines.html"
    },
    {
      "src": "/inventory",
      "dest": "/public/inventory.html"
    },
    {
      "src": "/customers",
      "dest": "/public/customers.html"
    },
    {
      "src": "/reports",
      "dest": "/public/reports.html"
    },
    {
      "src": "/settings",
      "dest": "/public/settings.html"
    },
    {
      "src": "/staff",
      "dest": "/public/staff.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
